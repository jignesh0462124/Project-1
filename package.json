{
  "name": "codesync-app",
  "version": "1.0.0",
  "description": "Real-time Collaborative Code Editor - Retro Gaming Theme",
  "main": "index.js",
  "scripts": {
    "dev": "concurrently \"npm run server:dev\" \"npm run client:dev\"",
    "start": "concurrently \"npm run server:start\" \"npm run client:start\"",
    "server:dev": "cd server && npm run dev",
    "server:start": "cd server && npm start",
    "client:dev": "cd client && npm run dev",
    "client:start": "cd client && npm run preview",
    "install:all": "npm install && cd server && npm install && cd ../client && npm install",
    "build": "cd client && npm run build",
    "setup": "npm run install:all && npm run setup:env",
    "setup:env": "cd server && cp .env.example .env && cd ../client && cp .env.example .env"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/your-username/codesync-app.git"
  },
  "keywords": [
    "collaborative-editor",
    "real-time",
    "code-editor",
    "socket.io",
    "react",
    "monaco-editor",
    "hackathon",
    "pair-programming"
  ],
  "author": "CodeSync Team",
  "license": "MIT"
}